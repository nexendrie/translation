application:
    scanDirs: false
    mapping:
        *: NetteModule\*Presenter
routing:
    routes:
        '<presenter>/<action>[/<id>]': "Micro:default"
extensions:
    translation: Nexendrie\Translation\Bridges\NetteDI\TranslationExtension
    fakeSession: Nexendrie\Translation\FakeSession\FakeSessionExtension
mytester:
    colors: true
    coverageFormat: cobertura
