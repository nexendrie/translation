{
    "name": "nexendrie/translation",
    "description": "Easy translating of PHP applications",
    "keywords": [
      "translation", "translating", "localization", "nette", "neon", "json", "ini", "yaml", "toml"
    ],
    "license": "BSD-3-Clause",
    "homepage": "https://nexendrie.gitlab.io",
    "authors": [
        {
            "name": "Jakub Konečný",
            "email": "jakub.konecny2@centrum.cz",
            "role": "Developer"
        }
    ],
    "support": {
        "docs": "https://nexendrie.gitlab.io/translation"
    },
    "require": {
        "php": ">=8.3.0",
        "psr/event-dispatcher": "^1.0",
        "nette/utils": "^3.2.10 || ^4.0",
        "nette/finder": "^2.6 || ^3.0",
        "nexendrie/utils": "^1.9",
        "symfony/polyfill-php84": "^1.31"
    },
    "require-dev": {
        "ext-simplexml": "*",
        "nexendrie/code-quality": "dev-master",
        "nette/di": "^3.1.3",
        "nette/http": "^3.2",
        "tracy/tracy": "^2.6",
        "latte/latte": "^3.0",
        "symfony/yaml": "^6.0",
        "nette/neon": "^3.4.1",
        "nette/application": "^3.1.5",
        "devium/toml": "^1.0",
        "konecnyjakub/event-dispatcher": "^2.2"
    },
    "suggest": {
        "nette/di": "For easier integration to Nette applications",
        "tracy/tracy": "For debugger panel",
        "nette/neon": "To use NeonLoader",
        "ext-json": "To use JsonLoader",
        "symfony/yaml": "To use YamlLoader",
        "nette/application": "To use param locale resolver in Nette applications",
        "nette/http": "To use session and header locale resolvers",
        "devium/toml": "To use TomlLoader"
    },
    "conflict": {
        "nette/di": "<3.1.3",
        "tracy/tracy": "<2.6",
        "latte/latte": "<2.8",
        "symfony/yaml": "<6.0",
        "nette/neon": "<3.4.1",
        "nette/application": "<3.1.5",
        "devium/toml": "<1.0"
    },
    "autoload": {
        "psr-4": {
            "Nexendrie\\Translation\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Nexendrie\\Translation\\": "tests/Nexendrie/Translation/"
        }
    },
    "config": {
        "classmap-authoritative": true
    },
    "extra": {
        "branch-alias": {
            "dev-master": "2.7.x-dev"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
